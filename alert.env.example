# Alert delivery config. Copy to state/alert.env (gitignored) and uncomment what
# you need. With NONE of these set, alerts are still evaluated and appended to
# state/alerts.log — external delivery is purely additive.

# Generic JSON webhook. POSTs {"text","subject","transitions"}; the "text" field
# is Slack/Mattermost-compatible.
#MONITOR_ALERT_WEBHOOK=https://hooks.example.com/services/XXX

# Email via SMTP (stdlib smtplib — no dependency).
#MONITOR_ALERT_SMTP_HOST=smtp.example.internal
#MONITOR_ALERT_SMTP_PORT=25
#MONITOR_ALERT_SMTP_STARTTLS=1
#MONITOR_ALERT_SMTP_USER=
#MONITOR_ALERT_SMTP_PASS=
#MONITOR_ALERT_EMAIL_FROM=monitor@workbench
#MONITOR_ALERT_EMAIL_TO=you@example.com

# Dead-man's switch: pinged on every successful run so an external service
# (healthchecks.io, Uptime Kuma push, etc.) alerts if this evaluator stops.
#MONITOR_ALERT_HEARTBEAT_URL=https://hc-ping.com/your-uuid
